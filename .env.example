# Copy to `.env` and adjust. `make up` reads this file.

# ---- Auth ----
# Shared secret between pretext.plus and this server (same scheme as the
# lightweight build server). Use a long random value in production.
BUILD_TOKEN=testtoken

# ---- Build backend (this is the swappable part) ----
#
# FAST LOCAL TEST MODE (default): a tiny image runs a fake build that just
# writes an output/ directory. Exercises the entire pipeline (queue, sandbox,
# artifact packaging, API) in seconds with no multi-GB image pull. Use this to
# develop and validate the server on your laptop before paying for a droplet.
BUILD_IMAGE=alpine
BUILD_COMMAND=mkdir -p output && echo '<html><body>FAKE build OK for target {target}</body></html>' > output/index.html && echo 'fake build complete'

# REAL MODE: comment the two lines above, uncomment these. Use the "warm" image
# (built by `make warm-image`), which bakes in PreTeXt's first-run setup so
# builds are fast and need no network. (Plain `pretextbook/pretext-full` also
# works but re-does that setup every build and needs BUILD_NETWORK=bridge.)
#BUILD_IMAGE=pretext-plus-build:warm
#BUILD_COMMAND=pretext build {target}

# ---- Sandbox limits (applied to every build container) ----
# With the warm image, assets are pre-baked, so the build needs no network.
# If you use plain pretextbook/pretext-full instead, set this to "bridge" so
# the per-build npm install / runestone downloads can reach the internet.
BUILD_NETWORK=none
BUILD_MEM_LIMIT=2g
BUILD_CPUS=2
BUILD_PIDS_LIMIT=512
BUILD_TIMEOUT=600
# User the build runs as. Empty = the image's default user (root in the warm
# image, where ~/.ptx is baked). Must match the warm image's USER.
BUILD_USER=
# HOME override. Empty = use the image's HOME (where ~/.ptx is baked). Leave
# empty unless you changed the warm image's user/home.
BUILD_HOME=
OUTPUT_SUBDIR=output

# ---- Reverse proxy (Caddy) ----
# How Caddy serves the API:
#   :80                       -> plain HTTP, for local testing (default)
#   build-full.pretext.plus   -> automatic HTTPS (Let's Encrypt) on a real domain
#
# This server is called machine-to-machine (from pretext.plus / the lite build
# server), NOT by browsers, so it does not need a "nice" public hostname the
# way build.pretext.plus (the lite server) does. Still, give it its own
# dedicated subdomain rather than reusing build.pretext.plus, so Caddy can get
# its own cert and you can lock it down independently. Recommended:
#   1. In Cloudflare, add an A record for this subdomain -> the droplet's IP,
#      with the proxy OFF ("DNS only" / grey cloud, not orange). This is a
#      server-to-server API, not a website, so Cloudflare's proxy adds nothing
#      -- and it would mask real client IPs, breaking the firewall allowlist
#      below.
#   2. Set SITE_ADDRESS to that subdomain.
#   3. Restrict who can reach it with a DigitalOcean Cloud Firewall: allow port
#      443 only from known IPs (your testing IP + whatever IP pretext.plus
#      calls from), leave port 80 open to everyone (it only ever serves the
#      harmless Let's Encrypt ACME challenge/redirect). See the README's
#      "Restricting access" section.
SITE_ADDRESS=:80

# ---- Completion callback (optional webhook) ----
# If a /builds request includes a `callback_url` form field, the worker POSTs
# the final job status there when the build finishes (instead of the client
# polling GET /builds/{id}). The body is HMAC-signed (X-PreTeXt-Signature:
# sha256=<hex>) so the receiver can authenticate it; the secret is never sent.
CALLBACK_TIMEOUT=10
CALLBACK_RETRIES=3
# Secret used to sign callback payloads. Defaults to BUILD_TOKEN if unset, but
# a dedicated value is preferred so submit and callback don't share a credential.
CALLBACK_SECRET=
# Comma-separated host allowlist for callback URLs. This is the PRIMARY SSRF
# control and should be set in production, e.g. CALLBACK_ALLOWED_HOSTS=pretext.plus
# Empty = allow any public host (IP-range checks still apply as a backstop).
CALLBACK_ALLOWED_HOSTS=
# SSRF guard: callback URLs resolving to loopback/private/link-local/reserved
# IPs are rejected by default. Set true ONLY for local dev with a localhost or
# private-network receiver.
CALLBACK_ALLOW_PRIVATE_IPS=

# ---- Storage ----
JOB_TTL=86400
# Set automatically by `make up`. Only needed if you run `docker compose`
# directly: export HOST_DATA_DIR=$PWD/data
HOST_DATA_DIR=
